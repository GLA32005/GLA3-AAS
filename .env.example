# AgentSec 后端环境变量模板
# 生产部署时请复制为 .env 并修改密钥

# 数据库连接 (容器内部建议保持默认)
DATABASE_URL=postgresql+asyncpg://agentsec:agentsec_pwd@db:5432/agentsec

# Redis 连接
REDIS_URL=redis://redis:6379/0

# 安全密钥 (必须修改！建议使用 openssl rand -hex 32 生成)
SECRET_KEY=agentsec_production_secret_change_me_now_2024

# JWT 过期时间 (分钟)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# [可选] 前端访问地址 (用于 CORS)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
