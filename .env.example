# --- 后端配置 ---
# 数据库连接 (容器内部网络直接使用 db 域名)
DATABASE_URL=postgresql+asyncpg://agentsec:agentsec_pwd@db:5432/agentsec

# Redis 连接 (容器内部网络直接使用 redis 域名)
REDIS_URL=redis://redis:6379/0

# --- 前端配置 ---
# 重要：请填写您云服务器的【公网 IP】或【域名】
# 浏览器将使用此地址请求后端 API
VITE_API_URL=http://<您的服务器公网IP>:8000

# --- 数据库配置 (Postgres) ---
POSTGRES_USER=agentsec
POSTGRES_PASSWORD=agentsec_pwd
POSTGRES_DB=agentsec
